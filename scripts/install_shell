#!/usr/bin/env bash

set -eu

# Detect Fedora Atomic / immutable ostree systems (Bazzite, Silverblue, etc.)
is_fedora_atomic() {
    [ -f /run/ostree-booted ]
}

# Find system zsh (prefer /bin/zsh or /usr/bin/zsh over brew/nix)
if [ -x /bin/zsh ]; then
    ZSH_PATH=/bin/zsh
elif [ -x /usr/bin/zsh ]; then
    ZSH_PATH=/usr/bin/zsh
else
    echo "Installing zsh..."
    if [ "$(uname)" = "Darwin" ]; then
        echo "zsh ships with macOS"
    else
        # Ensure Linuxbrew is available then use it for zsh (avoids rpm-ostree on Bazzite)
        if ! command -v brew >/dev/null 2>&1; then
            /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
            eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv bash)"
        fi
        brew install zsh
    fi
    ZSH_PATH="$(command -v zsh)"
fi

# Use Zsh
if [ "$SHELL" != "$ZSH_PATH" ]; then
    echo "Switching to Zsh ($ZSH_PATH)"
    if ! grep -qx "$ZSH_PATH" /etc/shells; then
        echo "$ZSH_PATH" | sudo tee -a /etc/shells
    fi
    if command -v chsh >/dev/null 2>&1; then
        sudo chsh -s "$ZSH_PATH" "${USER}"
    elif command -v usermod >/dev/null 2>&1; then
        sudo usermod -s "$ZSH_PATH" "${USER}"
    else
        echo "WARNING: Could not change shell automatically. Run: sudo usermod -s $ZSH_PATH $USER"
    fi
fi

if [ "$(uname)" = "Darwin" ]; then
    # macOS: Source nix and run nix-darwin
    if [ -f "/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh" ]; then
        . "/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh"
    fi
    USERNAME="$(whoami)"
    echo "Running nix-darwin switch for: $USERNAME"
    if command -v darwin-rebuild >/dev/null 2>&1; then
        sudo -H darwin-rebuild switch --flake ~/dotfiles/nix#"$USERNAME"
    else
        sudo -H nix run nix-darwin -- switch --flake ~/dotfiles/nix#"$USERNAME"
    fi
else
    # Linux: install CLI packages via Homebrew
    if ! command -v brew >/dev/null 2>&1; then
        echo "Installing Homebrew..."
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
        eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv bash)"
    fi
    DOTFILES_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
    echo "Installing Linux packages via Brewfile.linux..."
    brew bundle --file="$DOTFILES_DIR/Brewfile.linux" --no-upgrade
fi

# Link dotfiles
touch "$HOME"/.localrc
"$HOME"/dotfiles/scripts/stow
