#!/usr/bin/env bash

# This file installs tools not available in Homebrew (or not well-served by it).

# deno
if ! command -v deno >/dev/null 2>&1; then
    curl -fsSL https://deno.land/x/install/install.sh | sh
fi

# Rust
if ! command -v cargo >/dev/null 2>&1; then
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh
fi

# bws (Bitwarden Secrets CLI, not in nixpkgs)
if ! command -v bws >/dev/null 2>&1; then
    cargo install bws --locked
fi

# tfswitch (not in nixpkgs)
if ! command -v tfswitch >/dev/null 2>&1; then
    mkdir -p "$HOME/.local/bin"
    curl -L https://raw.githubusercontent.com/warrensbox/terraform-switcher/master/install.sh | bash -s -- -b "$HOME/.local/bin"
fi

if [ ! -f "$NVM_DIR/nvm.sh" ]; then
    echo "Installing nvm"
    PROFILE=/dev/null bash -c 'curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.3/install.sh | bash'
    zsh -lic "nvm install 20" # node 20
    zsh -lic "nvm use 20"
    zsh -lic "nvm alias default 20"
fi

# Kitty (doesnt work well from nix)
# On macOS, kitty installs as an app bundle not in PATH — check the bundle directly
if ! command -v kitty >/dev/null 2>&1 && [ ! -d "/Applications/kitty.app" ]; then
    curl -L https://sw.kovidgoyal.net/kitty/installer.sh | sh /dev/stdin
fi

# Claude (not in nixpkgs)
if ! command -v claude >/dev/null 2>&1 ; then
    curl -fsSL https://claude.ai/install.sh | bash
fi

# stack-sync
if ! command -v stack-sync >/dev/null 2>&1; then
    curl -fsSL https://raw.githubusercontent.com/kyeotic/stack-sync/main/install | bash
fi

# vault-sync
if ! command -v vault-sync >/dev/null 2>&1; then
    curl -fsSL https://raw.githubusercontent.com/kyeotic/vault-sync/main/install | bash
fi

# vault-sync: save BWS machine access token if not already set
if ! grep -q "BWS_ACCESS_TOKEN=." "$HOME/.bws" 2>/dev/null; then
    echo ""
    echo "vault-sync requires a Bitwarden Secrets machine access token."
    echo "Generate one here:"
    echo "  https://vault.bitwarden.com/#/sm/28ab20e5-7f26-4962-85fc-b3dd00011d9e/machine-accounts/ff76e921-089d-4af9-b7cf-b3dd0038af59/projects"
    echo ""
    printf "Paste your machine access token: "
    read -r BWS_TOKEN
    echo "BWS_ACCESS_TOKEN=$BWS_TOKEN" > "$HOME/.bws"
    echo "Token saved to ~/.bws"
fi

# Linux: install Nerd Fonts (Linuxbrew doesn't support casks)
if [[ "$(uname)" == "Linux" ]]; then
    if ! fc-list 2>/dev/null | grep -qi "Hack Nerd Font"; then
        echo "Installing Nerd Fonts (Hack, Meslo, FiraCode)..."
        FONTS_DIR="$HOME/.local/share/fonts"
        mkdir -p "$FONTS_DIR"
        for font in Hack Meslo FiraCode; do
            tmp=$(mktemp -d)
            curl -fsSL "https://github.com/ryanoasis/nerd-fonts/releases/latest/download/${font}.zip" \
                -o "$tmp/${font}.zip"
            unzip -q "$tmp/${font}.zip" -d "$tmp/${font}"
            find "$tmp/${font}" -name "*.ttf" -o -name "*.otf" | xargs -I{} cp {} "$FONTS_DIR/"
            rm -rf "$tmp"
        done
        fc-cache -fv >/dev/null 2>&1
    fi

    # Start syncthing as a systemd user service (installed via Brewfile.linux)
    if command -v brew >/dev/null 2>&1 && command -v syncthing >/dev/null 2>&1; then
        if ! systemctl --user is-enabled homebrew.syncthing.service >/dev/null 2>&1; then
            brew services start syncthing
        fi
    fi

    # Discord flatpak: grant access to the secret service so login tokens survive reboots
    if flatpak list --app 2>/dev/null | grep -q com.discordapp.Discord; then
        flatpak override --user --talk-name=org.freedesktop.secrets com.discordapp.Discord
    fi
fi

# Homebrew for macOS (Linux gets brew from install_shell)
if [[ "$(uname)" == "Darwin" ]] && ! command -v brew >/dev/null 2>&1; then
    echo "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    eval "$(/opt/homebrew/bin/brew shellenv bash)"
fi

# macOS: install CLI tools and GUI apps via Homebrew
if [[ "$(uname)" == "Darwin" ]] && command -v brew >/dev/null 2>&1; then
    DOTFILES_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

    # Cache sudo credentials once and keep them alive so each cask install
    # doesn't prompt separately (each `brew install --cask` calls sudo independently).
    sudo -v
    while true; do sudo -n true; sleep 60; kill -0 "$$" || exit; done 2>/dev/null &
    SUDO_KEEPALIVE_PID=$!

    echo "Installing CLI tools (Brewfile.linux)..."
    brew bundle --file="$DOTFILES_DIR/Brewfile.linux" --no-upgrade

    echo "Installing GUI apps (Brewfile)..."
    brew bundle --file="$DOTFILES_DIR/Brewfile" --no-upgrade --force

    kill "$SUDO_KEEPALIVE_PID" 2>/dev/null
fi