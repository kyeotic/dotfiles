#!/bin/bash

# Run with
# /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/kyeotic/dotfiles/HEAD/scripts/install)"
# Test with
# wsl --install Ubuntu --name utest
#
# Safe to run multiple times — each step is idempotent.

set -u

# Detect Fedora Atomic / immutable ostree systems (Bazzite, Silverblue, etc.)
is_fedora_atomic() {
    [ -f /run/ostree-booted ]
}

# Cache sudo credentials once upfront so repeated sudo calls don't each prompt.
# On Bazzite/KDE this triggers the ksshaskpass GUI dialog once.
sudo true

# Install minimal dependencies (git + curl)
# Skip on Fedora Atomic — git/curl are pre-installed and dnf is shimmed to rpm-ostree
if [ "$(uname -s)" = "Linux" ] && ! is_fedora_atomic; then
    if command -v apt >/dev/null 2>&1; then
        sudo apt update
        sudo apt install -y git curl
    elif command -v dnf >/dev/null 2>&1; then
        sudo dnf install -y git curl
    elif command -v pacman >/dev/null 2>&1; then
        sudo pacman -S --noconfirm git curl
    fi
fi

# Install Nix on macOS only (used for nix-darwin system management)
if [ "$(uname -s)" = "Darwin" ]; then
    # Source nix for the current session (must happen before the install check so
    # that `command -v nix` works on systems where nix is installed but not in PATH)
    if [ -f "/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh" ]; then
        . "/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh"
    fi

    if ! command -v nix >/dev/null 2>&1; then
        echo "Installing Nix..."
        curl --proto '=https' --tlsv1.2 -sSf -L https://install.determinate.systems/nix | sh -s -- install --no-confirm
    fi
fi

# Clone repo if not present
if [ ! -d "$HOME/dotfiles/.git" ]; then
    cd $HOME
    git clone https://github.com/kyeotic/dotfiles.git
    cd dotfiles
    git remote set-url origin git@github.com:kyeotic/dotfiles.git
    ./scripts/setup-ssh
fi

$HOME/dotfiles/scripts/init
