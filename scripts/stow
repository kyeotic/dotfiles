#!/usr/bin/env bash

# Link Config and home
mkdir -p ~/.config

stow -d $HOME/dotfiles -t ~/.config -S .config/ --adopt 
stow -d $HOME/dotfiles -t ~/ -S home
mkdir -p ~/.config/autokey/data
stow -d $HOME/dotfiles -t ~/.config/autokey/data -S autokey

# Services co-located with their configs, need to live in systemd/user
mkdir -p ~/.config/systemd/user
ln -sf ~/dotfiles/.config/espanso/espanso.service ~/.config/systemd/user/espanso.service
ln -sf ~/dotfiles/.config/conky/conky.service ~/.config/systemd/user/conky.service
systemctl --user daemon-reload 2>/dev/null || true

# kwin scripts live in ~/.local/share, not ~/.config
mkdir -p ~/.local/share/kwin/scripts
# stow -d $HOME/dotfiles/.config/kwin -t ~/.local/share/kwin -S scripts --adopt
# stow -d $HOME/dotfiles/.config/kwin/scripts -t $HOME/.local/share/kwin/scripts -S window-snap
# stow -d $HOME/dotfiles/.config/kwin -t $HOME/.local/share/kwin/scripts -S window-snap
ln -sf ~/dotfiles/.config/kwin/scripts/window-snap ~/.local/share/kwin/scripts/window-snap
ln -sf ~/dotfiles/.config/kwin/scripts/toggle-panel ~/.local/share/kwin/scripts/toggle-panel



# if [[ -a $HOME/.hyper.js ]]; then rm $HOME/.hyper.js; fi
# ln $HOME/dotfiles/configs/.hyper.js $HOME/.hyper.js 