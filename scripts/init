#!/usr/bin/env bash

set -eu

$HOME/dotfiles/scripts/install_shell
$HOME/dotfiles/scripts/install_apps

# Sync vault secrets if config exists
if command -v vault-sync >/dev/null 2>&1 && [[ -f "$HOME/dotfiles/.vault-sync.toml" ]]; then
  (cd "$HOME/dotfiles" && vault-sync sync)
fi

printf "\n\nInstall Complete\nStart a new terminal for all changes to take effect"