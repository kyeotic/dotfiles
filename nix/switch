#!/usr/bin/env bash

set -eu

# Detect platform and user
USERNAME="$(whoami)"

if [ "$(uname)" = "Darwin" ]; then
  echo "Switching darwin config for: $USERNAME"
  if command -v darwin-rebuild >/dev/null 2>&1; then
    sudo -H darwin-rebuild switch --flake ~/dotfiles/nix#"$USERNAME"
  else
    # Bootstrap nix-darwin on first run
    echo "darwin-rebuild not found, bootstrapping nix-darwin..."
    sudo -H nix run nix-darwin -- switch --flake ~/dotfiles/nix#"$USERNAME"
  fi
  /System/Library/PrivateFrameworks/SystemAdministration.framework/Resources/activateSettings -u
else
  echo "nix/switch is only supported on macOS. Linux packages are managed by Homebrew."
  echo "Run: brew bundle --file=~/dotfiles/Brewfile.linux"
  exit 1
fi
