#!/usr/bin/env bash

function colorize-log {
  colorize red ERROR | \
  colorize yellow 'WARN(ING)?' | \
  colorize green INFO | \
  colorize white DEBUG | \
  colorize white TRACE | \
  colorize red error | \
  colorize yellow 'warn(ing)?' | \
  colorize green info | \
  colorize white debug | \
  colorize white trace
}

function colorize {
  COLOR="$1"; shift
  ack --flush --passthru --color --color-match="$COLOR" $@
}

function aws-me {
  aws sts get-caller-identity | jq -r '.Account'
}

function passgen {
  openssl rand -base64 $1
}

function g-prune-squashed {
  for branch in $(git for-each-ref --format='%(if:equals=[gone])%(upstream:track)%(then)%(refname:short)%(end)' refs/heads); do git branch -D $branch; done
}

function g-prune-sqaushed-dry {
  for branch in $(git for-each-ref --format='%(if:equals=[gone])%(upstream:track)%(then)%(refname:short)%(end)' refs/heads); do echo "$branch is ready to be deleted"; done
}

function install-xinput {
  sudo bash ~/dotfiles/bazzite/controller/install.sh
}

function setup-nas-mounts {
  local CREDENTIALS="/var/home/kyeotic/.smb-share"
  local UID_GID="uid=1000,gid=1000"
  local OPTS="credentials=${CREDENTIALS},${UID_GID},_netdev,nofail,vers=3.0"
  local -A SHARES=(
    [nas]="//kye-nas/nas"
    [media]="//kye-nas/media"
    [apps]="//kye-nas/apps"
  )

  for name in "${(@k)SHARES}"; do
    local share="${SHARES[$name]}"
    local mnt="/mnt/${name}"

    # Create mount point
    if [[ ! -d "$mnt" ]]; then
      echo "Creating mount point $mnt"
      sudo mkdir -p "$mnt"
    fi

    # Add fstab entry if not already present
    if ! grep -qsF "$share" /etc/fstab; then
      echo "Adding fstab entry for $share -> $mnt"
      echo "${share}  ${mnt}  cifs  ${OPTS}  0  0" | sudo tee -a /etc/fstab > /dev/null
    else
      echo "fstab entry for $share already exists, skipping"
    fi
  done

  echo "Done. Run 'sudo mount -a' to mount all shares."
}